# Copy this file to .env and fill in real values. Never commit the real .env file.

# MySQL connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=iris_store

# Random long secret used to sign admin login tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Bcrypt hash of your real admin password — generate with:
#   node hash-password.js "your-real-admin-password"
ADMIN_PASSWORD_HASH=replace_with_output_of_hash-password.js

PORT=3001
